
<html>
  <head>
    <style>
      #Ronaldo {
        border: 1px solid #CCC;
        width: 100px;
        height: 100px;
      }
    </style>
    <meta charset="utf-8">
  </head>
  <body>
    <h2>Ronaldo</h2>
    <div id="Ronaldo">Suiiiiiiii</div>
    <br>
    <button type="button" onclick="changeStyle()">Click Me</button>
    <script>
      function changeStyle() {
        var element = document.getElementById("Ronaldo");
        element.style.color = "#FF0000";
      }
    </script>
  </body>
</html>
